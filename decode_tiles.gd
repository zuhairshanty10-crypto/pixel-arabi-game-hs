@tool
extends SceneTree

func _init():
    var data_b64 = ""
    var raw_bytes = Marshalls.base64_to_raw(data_b64)
    
    for i in range(0, raw_bytes.size(), 20):
        if i + 20 > raw_bytes.size(): break
        var x = raw_bytes.decode_s32(i)
        var y = raw_bytes.decode_s32(i + 4)
        var source = raw_bytes.decode_s32(i + 8)
        var atlas_x = raw_bytes.decode_u16(i + 12)
        var atlas_y = raw_bytes.decode_u16(i + 14)
        var alt = raw_bytes.decode_s32(i + 16)
        print("Cell:(%d,%d) Source:%d Atlas:(%d,%d) Alt:%d" % [x, y, source, atlas_x, atlas_y, alt])
    quit()
