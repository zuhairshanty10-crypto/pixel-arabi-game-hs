; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Pixel Arabi"
config/description="A 2D platformer trap game"
config/version="0.1.0"
run/main_scene="res://scenes/MainMenu.tscn"
config/features=PackedStringArray("4.4")
run/max_fps=60
boot_splash/bg_color=Color(0.1, 0.1, 0.15, 1)
boot_splash/show_image=false
config/icon="res://icon.jpg"

[audio]

buses/default_bus_layout="default_bus_layout.tres"

[autoload]

GameManager="*res://scripts/autoload/GameManager.gd"
AudioManager="*res://scenes/autoload/AudioManager.tscn"
SaveManager="*res://scripts/autoload/SaveManager.gd"
Localization="*res://scripts/autoload/Localization.gd"
PauseMenu="*res://scenes/ui/PauseMenu.tscn"
InputManager="*res://scripts/autoload/InputManager.gd"
TouchControls="*res://scenes/ui/TouchControls.tscn"

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/size/mode=3
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"
window/handheld/orientation="landscape"
window/stretch/scale.android=1.5

